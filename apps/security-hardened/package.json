{
  "name": "fullstack-security-hardened",
  "version": "1.0.0",
  "description": "Security-hardened Express.js starter for Layer 8 of The Full Stack Observatory.",
  "main": "src/app.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "jest --runInBand",
    "lint": "eslint src tests",
    "audit:check": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "clearMocks": true,
    "testEnvironment": "node"
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "jest": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:security/recommended-legacy"
    ],
    "plugins": [
      "security"
    ],
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-console": "off"
    }
  }
}
