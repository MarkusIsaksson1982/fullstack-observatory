# PostgreSQL Connection Configuration
# Copy this file to .env and fill in your values

# Database connection URL (recommended)
# Format: postgresql://user:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fullstack_observatory_db

# OR individual connection parameters (alternative)
PGHOST=localhost
PGPORT=5432
PGDATABASE=fullstack_observatory_db
PGUSER=postgres
PGPASSWORD=postgres

# Migration settings
MIGRATIONS_DIR=migrations
SEED_FILE=seed/seed.sql

# Environment flag (development/staging/production)
NODE_ENV=development
