{
  "name": "fullstack-observatory",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "tsc --noEmit",
    "compose": "docker compose -f docker-compose.fullstack.yml --profile fullstack up -d --build",
    "compose:down": "docker compose -f docker-compose.fullstack.yml --profile fullstack down"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "@tsconfig/node20": "^1.0.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.x"
  }
}