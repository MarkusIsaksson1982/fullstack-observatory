{
  "name": "fullstack-observatory",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:doc-index": "node scripts/build-observatory-doc-index.js",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "tsc --noEmit",
    "compose": "docker compose -f docker-compose.fullstack.yml --profile fullstack up -d --build",
    "compose:down": "docker compose -f docker-compose.fullstack.yml --profile fullstack down"
  },
  "devDependencies": {
    "@tsconfig/node20": "^1.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  }
}
